<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- This tool takes a single NuGet dependency (Spectre.Console) for its CLI,
       so it needs nuget.org to restore. The package and its transitive deps are
       cached in the global packages folder after the first restore. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
